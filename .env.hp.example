# ─────────────────────────────────────────────────────────────────────────────
# .env.hp.example — overrides racine pour HP G4 SFF
# Copier en .env si tu co-localises plusieurs stacks sur le même host Docker.
#
# Contexte : l'architecture nominale (Sprint 23) place chaque stack dans son
# propre LXC Proxmox (infra: 10.10.10.2, forge: 10.10.10.10, oria: 10.10.10.20,
# etc.). Dans cette config, les ports host de chaque LXC sont indépendants,
# donc PAS DE COLLISION et ce fichier n'est pas nécessaire.
#
# Ce fichier sert si tu décides de regrouper plusieurs stacks dans un même
# LXC (ou directement sur l'host Docker), pour éviter les collisions de ports
# documentées dans docs/PORTS.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Forge — réallocation 30xxx ────────────────────────────────────────────
FORGE_FRONTEND_PORT=30000
FORGE_POSTGRES_PORT=30005
FORGE_PG_PATRONI_PORT=30008
FORGE_COTURN_PORT=30478           # public TURN reste sur 3478 via traefik
FORGE_NETBIRD_SIGNAL_PORT=30100   # public NetBird signal reste sur 10000 via traefik
FORGE_NETBIRD_MGMT_PORT=30073     # public NetBird mgmt reste sur 33073 via traefik

# ── Oria — réallocation 31xxx (frontend prod uniquement) ──────────────────
ORIA_FRONTEND_HOST_PORT=31000

# ── Keycloak (infra) — défaut 8080 inchangé ───────────────────────────────
# KEYCLOAK_HOST_PORT=8080  # ne pas changer : référencé par .env.example de toutes les apps

# ── Voir docs/PORTS.md pour la grille complète et la justification ────────
