# ============================================================
#  Calendar Service — copier en .env et remplir les valeurs
#  cp .env.example .env
#  Puis : docker compose up -d
# ============================================================


# ── BASE DE DONNÉES ──────────────────────────────────────────
# PostgreSQL recommandé en prod ; laisser vide pour SQLite dev
# postgresql://user:password@host:5432/calendar
CALENDAR_DATABASE_URL=


# ── REDIS (SSE fan-out) ──────────────────────────────────────
# Laisser vide pour désactiver (mono-instance uniquement)
# redis://redis:6379
CALENDAR_REDIS_URL=


# ── CORS ─────────────────────────────────────────────────────
# Origines autorisées séparées par virgule
# En prod : remplacer par l'URL publique du frontend
CALENDAR_CORS_ORIGINS=http://localhost:8300,http://localhost:3000


# ── TOKEN S2S ────────────────────────────────────────────────
# Partagé avec assistant/oria/forge pour les appels inter-services
# openssl rand -hex 32
CALENDAR_SERVICE_TOKEN=


# ── AUTH KEYCLOAK (false par défaut) ─────────────────────────
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=forge
KEYCLOAK_CLIENT_ID=calendar-app
# Audience JWT (multi-tenant) — vide = verify_aud désactivé
KEYCLOAK_AUDIENCE=
