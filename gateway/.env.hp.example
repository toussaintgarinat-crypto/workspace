# gateway/.env.hp.example — Copier en .env dans le LXC gateway (10.10.10.50)
# Remplacer NETBIRD_MAC_IP par l'IP NetBird réelle du Mac (netbird status sur le Mac)

LITELLM_MASTER_KEY=sk-master-change-this

OPENROUTER_API_KEY=sk-or-...

# Ollama sur Mac via NetBird
OLLAMA_MAC_URL=http://NETBIRD_MAC_IP:11434

# Ollama sur HP (LXC ollama-hp)
OLLAMA_HP_URL=http://10.10.10.60:11434
