# Usage standalone uniquement (docker compose -f gateway/docker-compose.yml).
# Via Makefile racine : cp .env.example .env && make seed-envs && make start-gateway

LITELLM_MASTER_KEY=sk-master-change-this
OPENROUTER_API_KEY=sk-or-...

# Ollama (local ou NetBird) — ex: http://100.x.x.x:11434 ou http://192.168.1.x:11434
# Laisser vide pour désactiver les modèles ollama/*
OLLAMA_URL=
