LITELLM_MASTER_KEY=sk-master-change-this
OPENROUTER_API_KEY=sk-or-...

# Ollama sur Mac (modèles lourds) — IP NetBird du Mac ou http://host.docker.internal:11434
# Laisser vide pour désactiver
OLLAMA_MAC_URL=

# Ollama sur HP (modèles légers CPU) — LXC ollama-hp, ex: http://10.10.10.60:11434
# Laisser vide pour désactiver
OLLAMA_HP_URL=
