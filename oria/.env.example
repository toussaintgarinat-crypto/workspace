# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://oria:oria_secret@db:5432/oria
POSTGRES_DB=oria
POSTGRES_USER=oria
POSTGRES_PASSWORD=change_this_in_production

# ── Keycloak Auth ────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080         # URL interne Docker; https://auth.votredomaine.com en prod
KEYCLOAK_REALM=oria
KEYCLOAK_CLIENT_ID=oria-app
# Frontend (exposed au navigateur — URL publique)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=oria
VITE_KEYCLOAK_CLIENT_ID=oria-app

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LiveKit ─────────────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
# OBLIGATOIRE — openssl rand -base64 32
LIVEKIT_API_SECRET=

# ── Matrix / Synapse ─────────────────────────────────────────
MATRIX_HOMESERVER_URL=http://synapse:8008
MATRIX_SERVER_NAME=oria.local
# OBLIGATOIRE — openssl rand -hex 32
MATRIX_AS_TOKEN=
# OBLIGATOIRE — openssl rand -hex 32
MATRIX_HS_TOKEN=
SYNAPSE_DB_PASSWORD=change_this_in_production

# ── Forge (IA agent — optionnel) ────────────────────────────
# URL du backend Forge. Sans Forge, Oria fonctionne seul (texte/voix uniquement).
FORGE_URL=http://localhost:3001
# Token d'auth agents résidents — laisser vide si Forge non utilisé
FORGE_TOKEN=
DEFAULT_AGENT_PROVIDER=openrouter
DEFAULT_AGENT_MODEL=anthropic/claude-sonnet-4-6

# ── MemPalace (mémoire — optionnel) ─────────────────────────
# Chemin local du palace ou URL d'un serveur Qdrant partagé avec Forge.
# ── MemPalace (opt-in) ───────────────────────────────────────
# Mode HTTP (recommandé) : pointe vers l'API MemPalace
# 1) Démarrer MemPalace : cd mempalace && make start
# 2) Créer un token : POST /auth/service-token (username/password)
MEMPALACE_API_URL=http://localhost:8100
MEMPALACE_API_TOKEN=

# Mode local (fallback si API URL absente) — Qdrant direct
MEMPALACE_PALACE_PATH=/home/user/.mempalace/palace
PALACE_BASE_PATH=/home/user/.mempalace/palaces
MEMPALACE_QDRANT_URL=

# ── Ollama Bridge (LLM local — optionnel) ───────────────────
# Permet aux agents Forge configurés avec ollama de joindre le LLM local.
# Lance infra/ollama-bridge/ puis renseigne l'URL dans les agents Oria.
# (URL Bridge : http://<IP-MAC>:11436)

# ── Stripe (optionnel) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_MATRIX_URL=http://localhost:8008
FRONTEND_URL=http://localhost:3000
