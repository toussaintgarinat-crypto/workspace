# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://oria:oria_secret@db:5432/oria
POSTGRES_DB=oria
POSTGRES_USER=oria
POSTGRES_PASSWORD=change_this_in_production

# ── JWT Auth ────────────────────────────────────────────────
JWT_SECRET=change_this_32_char_random_secret
COOKIE_SECURE=true   # false en dev (HTTP), true en prod (HTTPS)

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LiveKit ─────────────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change_this_livekit_secret

# ── Matrix / Synapse ─────────────────────────────────────────
MATRIX_HOMESERVER_URL=http://synapse:8008
MATRIX_SERVER_NAME=oria.local
MATRIX_AS_TOKEN=change_this_application_service_token
MATRIX_HS_TOKEN=change_this_homeserver_token
SYNAPSE_DB_PASSWORD=change_this_in_production

# ── Stripe (optionnel) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_MATRIX_URL=http://localhost:8008
FRONTEND_URL=http://localhost:3000
