# oria/.env.hp.example — Copier en .env dans le LXC oria (10.10.10.20)

POSTGRES_DB=oria
POSTGRES_USER=oria
POSTGRES_PASSWORD=oria_secret

# CORS — ajouter l'IP NetBird du HP pour l'accès depuis téléphone
# Remplacer NETBIRD_HP_IP par l'IP réelle (netbird status sur le HP)
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3000,http://NETBIRD_HP_IP:3002

# Keycloak dans le LXC infra
KEYCLOAK_URL=http://10.10.10.2:8080
KEYCLOAK_REALM=oria
KEYCLOAK_CLIENT_ID=oria-app

# Matrix / Synapse
MATRIX_SERVER_NAME=oria.local
MATRIX_AS_TOKEN=5c95b040fc487db2901d458463a84b187a521e647e6d2ad14a7fe8d4a4eac097
MATRIX_HS_TOKEN=216582996e3addbb9eba6327a3fa3a3760c11da3226b6aa3f3cce2b2b87445f1

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_oria_local_dev_key_32chars

SYNAPSE_DB_PASSWORD=synapse_secret
