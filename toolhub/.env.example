# ─── Base de données ─────────────────────────────────────────────────────────
# PostgreSQL en production. Si vide, SQLite local (dev uniquement).
TOOLHUB_DATABASE_URL=postgresql://toolhub:password@postgres:5432/toolhub
# DB_PATH=./toolhub.db

# ─── Redis ───────────────────────────────────────────────────────────────────
TOOLHUB_REDIS_URL=redis://redis:6379/3

# ─── Chiffrement credentials ─────────────────────────────────────────────────
# OBLIGATOIRE en production.
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOOLHUB_ENCRYPTION_KEY=

# ─── Authentification Keycloak ────────────────────────────────────────────────
AUTH_ENABLED=false
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=forge
KEYCLOAK_CLIENT_ID=toolhub-app
KEYCLOAK_AUDIENCE=

# ─── Token S2S inter-services ────────────────────────────────────────────────
# Partagé avec Assistant et Forge. Utilisé comme Bearer token S2S.
# L'appelant doit aussi fournir le header X-User-Id.
TOOLHUB_SERVICE_TOKEN=

# ─── CORS ────────────────────────────────────────────────────────────────────
TOOLHUB_CORS_ORIGINS=http://localhost:3000,http://localhost:8300

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Registry ────────────────────────────────────────────────────────────────
TOOLHUB_DEFAULT_CACHE_TTL=60
TOOLHUB_EXECUTION_LOG_MAX_ROWS=10000
