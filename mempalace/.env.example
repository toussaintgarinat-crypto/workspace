# Usage standalone uniquement (docker compose -f mempalace/docker-compose.yml).
# Via Makefile racine : cp .env.example .env && make seed-envs && make start-mempalace
# Note : les variables sont traduites depuis MEMPALACE_JWT_SECRET → JWT_SECRET, etc.

# ── JWT Auth ────────────────────────────────────────────────────
# openssl rand -base64 32
JWT_SECRET=change_this_in_production
JWT_EXPIRE_MINUTES=1440

# Token requis pour créer des comptes supplémentaires après le premier
# openssl rand -hex 24
MEMPALACE_ADMIN_TOKEN=change_this_admin_token

# ── Qdrant ──────────────────────────────────────────────────────
# Laisser vide pour mode fichier local (pas de serveur Qdrant)
# Docker : se remplit automatiquement via docker-compose
MEMPALACE_QDRANT_URL=

# ── Données ─────────────────────────────────────────────────────
# Dossier de base des palais (un sous-dossier par utilisateur)
MEMPALACE_PALACE_BASE=~/.mempalace/palaces
MEMPALACE_DB_PATH=~/.mempalace/users.db

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Stockage (local ou S3/MinIO) ─────────────────────────────────
# "local" (défaut) ou "s3" (MinIO)
MEMPALACE_STORAGE=local
# Requis si MEMPALACE_STORAGE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mempalace
# openssl rand -base64 16
S3_SECRET_KEY=mempalace_secret_change_this
S3_BUCKET=mempalace

# ── MinIO (si lancé via docker-compose) ─────────────────────────
MINIO_ROOT_USER=mempalace
# openssl rand -base64 16
MINIO_ROOT_PASSWORD=mempalace_secret_change_this

# ── Keycloak (dual-auth optionnel) ──────────────────────────────
KEYCLOAK_URL=
KEYCLOAK_REALM=forge
# Keycloak audience (multi-tenant) — valeur = client_id Keycloak du service. Vide = verify_aud désactivé (single-tenant).
KEYCLOAK_AUDIENCE=mempalace-app

# ── LLM Gateway (optionnel — pour la classification IPCRA) ───────
GATEWAY_URL=
GATEWAY_API_KEY=sk-mempalace
GATEWAY_MODEL=openai/gpt-4o-mini
