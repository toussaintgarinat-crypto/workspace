# ── JWT Auth ────────────────────────────────────────────────────
# openssl rand -base64 32
JWT_SECRET=change_this_in_production
JWT_EXPIRE_MINUTES=1440

# Token requis pour créer des comptes supplémentaires après le premier
# openssl rand -hex 24
MEMPALACE_ADMIN_TOKEN=change_this_admin_token

# ── Qdrant ──────────────────────────────────────────────────────
# Laisser vide pour mode fichier local (pas de serveur Qdrant)
# Docker : se remplit automatiquement via docker-compose
MEMPALACE_QDRANT_URL=

# ── Données ─────────────────────────────────────────────────────
# Dossier de base des palais (un sous-dossier par utilisateur)
MEMPALACE_PALACE_BASE=~/.mempalace/palaces
MEMPALACE_DB_PATH=~/.mempalace/users.db

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
