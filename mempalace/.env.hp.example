# mempalace/.env.hp.example — Copier en .env dans le LXC mempalace (10.10.10.30)

JWT_SECRET=change_this_jwt_secret_in_production

# Token admin pour créer des comptes supplémentaires
MEMPALACE_ADMIN_TOKEN=change_this_admin_token

# Gateway LiteLLM dans le LXC gateway
GATEWAY_URL=http://10.10.10.50:4000
GATEWAY_API_KEY=sk-mempalace
GATEWAY_MODEL=openai/gpt-4o-mini

# CORS — ajouter l'IP NetBird du HP pour l'accès depuis téléphone
# Remplacer NETBIRD_HP_IP par l'IP réelle (netbird status sur le HP)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://NETBIRD_HP_IP:8100

# Stockage MinIO (activé par défaut en local, passer à "s3" pour MinIO)
MEMPALACE_STORAGE=local
