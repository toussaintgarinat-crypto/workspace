# assistant/.env.hp.example — Copier en .env dans le LXC assistant (10.10.10.40)

# Gateway LiteLLM dans le LXC gateway
GATEWAY_URL=http://10.10.10.50:4000
GATEWAY_API_KEY=sk-assistant
GATEWAY_MODEL=openai/gpt-4o

# Keycloak dans le LXC infra
KEYCLOAK_URL=http://10.10.10.2:8080
KEYCLOAK_REALM=forge
AUTH_ENABLED=false

# Vault pour le chiffrement AES-256 des tokens (sprint 22)
VAULT_SECRET=change_this_vault_secret_in_production_32chars

# CORS — ajouter l'IP NetBird du HP pour l'accès depuis téléphone
# Remplacer NETBIRD_HP_IP par l'IP réelle (netbird status sur le HP)
CORS_ORIGINS=http://localhost:8300,http://localhost:3000,http://NETBIRD_HP_IP:8300
