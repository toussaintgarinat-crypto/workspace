# Usage standalone uniquement (docker compose -f assistant/docker-compose.yml).
# Via Makefile racine : cp .env.example .env && make seed-envs && make start-assistant

# ── Gateway LiteLLM ─────────────────────────────────────────
# En Docker : http://localhost:4000 (si même hôte) ou http://<IP-SERVEUR>:4000
GATEWAY_URL=http://localhost:4000
GATEWAY_API_KEY=sk-assistant
# openssl rand -hex 32
GATEWAY_MASTER_KEY=
GATEWAY_MODEL=openai/gpt-4o

# ── CORS (frontend autorisé à appeler le backend) ────────────
# En prod, remplacer par l'URL publique du frontend : https://assistant.example.com
CORS_ORIGINS=http://localhost:8300,http://localhost:3000

# ── Auth Keycloak (optionnel — false par défaut) ─────────────
AUTH_ENABLED=false
# En Docker : http://localhost:8080 (si même hôte) ou http://<IP-SERVEUR>:8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=assistant-app
# Keycloak audience (multi-tenant) — valeur = client_id Keycloak du service. Vide = verify_aud désactivé (single-tenant).
KEYCLOAK_AUDIENCE=assistant-app
# openssl rand -base64 32
VAULT_SECRET=change_this_vault_secret_in_production_32chars

# ── Base de données (optionnel — SQLite par défaut) ──────────
# Laisser vide pour SQLite local. Renseigner pour PostgreSQL :
# ASSISTANT_DATABASE_URL=postgresql://user:password@host:5432/assistant
ASSISTANT_DATABASE_URL=

# ── Redis (requis pour scaler — pub/sub SSE + leader election) ──
ASSISTANT_REDIS_URL=redis://redis:6379

# ── Summarizer de conversation ────────────────────────────────
SUMMARIZE_ENABLED=true
SUMMARIZE_THRESHOLD=20

# ── Notifications ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── RAG ──────────────────────────────────────────────────────
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.7

# ── Voice locale (faster-whisper + Kokoro) ───────────────────
LOCAL_VOICE_ENABLED=false
# Taille modèle Whisper : tiny | base | small | medium | large-v3
WHISPER_LOCAL_MODEL=base
# Voix Kokoro : af_heart | af_sky | af_bella | am_adam | bf_emma | bm_george
KOKORO_VOICE=af_heart
# Langue Kokoro : a=American EN | b=British EN
KOKORO_LANG=a
