# ============================================================
#  Configuration globale — copier en .env et remplir les valeurs
#  cp .env.example .env
#  Puis : make start
# ============================================================


# ── GATEWAY (LiteLLM) ────────────────────────────────────────
# Clé maître LiteLLM — à changer obligatoirement (openssl rand -hex 32)
LITELLM_MASTER_KEY=
GATEWAY_MASTER_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Serveur Ollama local (ex: http://100.x.x.x:11434 via NetBird, http://192.168.1.x:11434 en LAN)
# Laisser vide pour désactiver les modèles locaux
OLLAMA_URL=


# Tag d'image assistant injecté par CI/CD (sprint53) — format YYYYMMDD-SHA7
# En dev local: laisser vide pour utiliser :latest (image locale buildée par docker-compose)
# En prod: fourni automatiquement par make deploy-assistant
ASSISTANT_IMAGE_TAG=

# Sidecars optionnels (updater + disk-collector) — activés avec :
#   docker compose --profile sidecars up -d
# Laisser vide en dev local ; à renseigner uniquement sur le serveur de prod.
# COMPOSE_DIR = chemin absolu du dossier assistant/ sur le host
COMPOSE_DIR=
# STORAGE_PATH = chemin du stockage assistant sur le host (lu par disk-collector)
STORAGE_PATH=

# ── ASSISTANT ────────────────────────────────────────────────
# URL de la gateway LiteLLM vue par l'assistant (interne Docker ou hôte local)
GATEWAY_URL=http://localhost:4000
GATEWAY_API_KEY=sk-assistant
GATEWAY_MODEL=openai/gpt-4o

# CORS — origines autorisées à appeler le backend assistant
# En prod : remplacer par l'URL publique du frontend (ex: https://assistant.example.com)
CORS_ORIGINS=http://localhost:8300,http://localhost:3000

# Résumé automatique des conversations (seuil en nombre de messages)
SUMMARIZE_ENABLED=true
SUMMARIZE_THRESHOLD=20

# Auth Keycloak (false par défaut)
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=forge
KEYCLOAK_CLIENT_ID=assistant-app
# Keycloak audience (multi-tenant) — valeur = client_id du service (ex: assistant-app).
# Vide = verify_aud désactivé (single-tenant). Utilisé par assistant + mempalace + oria.
KEYCLOAK_AUDIENCE=
# openssl rand -base64 32
VAULT_SECRET=change_this_vault_secret_32_chars!!

# Base de données assistant — obligatoire pour scaler (vide = SQLite local)
# postgresql://user:password@host:5432/assistant
ASSISTANT_DATABASE_URL=

# Redis — obligatoire pour scaler (pub/sub SSE + leader election scheduler)
# Sans Redis : single-instance uniquement
ASSISTANT_REDIS_URL=redis://redis:6379

# RAG — injection automatique de souvenirs MemPalace dans le chat
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.7

# Voice locale (nécessite LOCAL_VOICE_ENABLED=true au docker build)
LOCAL_VOICE_ENABLED=false
WHISPER_LOCAL_MODEL=base
KOKORO_VOICE=af_heart
KOKORO_LANG=a

# OCR pour PDF scannés (doc_intelligence)
# Options : tesseract (local, défaut) | mistral (recommandé) | llm (via gateway vision)
OCR_PROVIDER=tesseract
# Requis si OCR_PROVIDER=mistral
MISTRAL_API_KEY=

# Kiwix — Wikipedia offline (S77)
# Laisser vide pour désactiver le tool. Activer : KIWIX_URL=http://kiwix:8080
KIWIX_URL=http://kiwix:8080
# Chemin host des fichiers ZIM (montés dans /data du container kiwix)
ZIM_PATH=/opt/assistant/zim

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=


# ── FORGE ────────────────────────────────────────────────────
# PostgreSQL Forge — injectés dans docker-compose.yml (POSTGRES_USER:-forge etc.)
POSTGRES_USER=forge
# openssl rand -base64 16
POSTGRES_PASSWORD=forge_secret_change_this
POSTGRES_DB=forge

# LLM par défaut dans Forge (ollama | anthropic | openai | groq)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# Clés LLM optionnelles
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Keycloak Forge
KEYCLOAK_ADMIN=admin
# openssl rand -base64 24
KEYCLOAK_ADMIN_PASSWORD=change_this_in_production
# openssl rand -base64 32
ENCRYPTION_KEY=change_this_32_char_random_key!!

# Emails (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# MinIO Forge
MINIO_ROOT_USER=forge
# openssl rand -base64 16
MINIO_ROOT_PASSWORD=forge_secret_change_this

# MemPalace (optionnel — intégration Forge)
MEMPALACE_API_URL=http://localhost:8100
MEMPALACE_API_TOKEN=


# ── MEMPALACE ────────────────────────────────────────────────
# openssl rand -base64 32
MEMPALACE_JWT_SECRET=change_this_in_production
# openssl rand -hex 24
MEMPALACE_ADMIN_TOKEN=change_this_admin_token

MEMPALACE_MINIO_USER=mempalace
MEMPALACE_MINIO_PASSWORD=mempalace_secret_change_this


# ── ORIA ─────────────────────────────────────────────────────
ORIA_POSTGRES_USER=oria
# openssl rand -base64 16
ORIA_POSTGRES_PASSWORD=change_this_in_production
ORIA_POSTGRES_DB=oria

# openssl rand -base64 32
ORIA_LIVEKIT_API_SECRET=change_this_livekit_secret_32_chars

# Matrix/Synapse
ORIA_MATRIX_SERVER_NAME=oria.local
# openssl rand -hex 32
ORIA_MATRIX_AS_TOKEN=change_this_application_service_token
# openssl rand -hex 32
ORIA_MATRIX_HS_TOKEN=change_this_homeserver_token
# openssl rand -hex 32 — utilisé par init-dendrite.sh
ORIA_MATRIX_REGISTRATION_SHARED_SECRET=change_this_matrix_registration_secret
# true = fermé, false = inscription publique ouverte (Sprint 71)
ORIA_MATRIX_REGISTRATION_DISABLED=true
# openssl rand -base64 16
ORIA_SYNAPSE_DB_PASSWORD=change_this_in_production

ORIA_MINIO_USER=oria
ORIA_MINIO_PASSWORD=oria_secret_change_this

# URLs publiques Oria (exposées au navigateur)
VITE_ORIA_API_URL=http://localhost:8000
VITE_ORIA_KEYCLOAK_URL=http://localhost:8080


# ── DÉPLOIEMENT PROD (Traefik HTTPS) ─────────────────────────
# Domaine racine pour les sous-domaines en prod (Traefik + Keycloak + Oria + Forge)
# Utilisé par oria/docker-compose.prod.yml et forge/docker-compose.prod.yml
# Exemples : KC_HOSTNAME=auth.${DOMAIN}, FRONTEND_URL=https://forge.${DOMAIN}
# Laisser vide en dev local.
DOMAIN=

# Mode production — active les fail-fast secrets dans les services Python (mempalace, etc.)
# Mettre à "production" sur le serveur (vide ou absent = dev permissif)
# Note : Forge (Node) utilise NODE_ENV=production, injecté automatiquement par docker-compose.prod.yml
ENV=

# IP NetBird du MacBook hôte Ollama, vue depuis le serveur de prod (Forge prod uniquement)
# Exemple : 100.64.0.2 — utilisé par OLLAMA_BASE_URL en prod
MACBOOK_NETBIRD_IP=


# ── OBSERVABILITÉ (Prometheus + Grafana) ─────────────────────
# Mot de passe admin Grafana
# openssl rand -base64 16
GF_SECURITY_ADMIN_PASSWORD=change_this_grafana_password

# URL publique Grafana (pour les redirects OAuth)
GRAFANA_ROOT_URL=http://localhost:3100

# Keycloak OIDC pour Grafana (SSO multi-utilisateurs)
# Créer un client "grafana" dans Keycloak (type: confidential, redirect: GRAFANA_ROOT_URL/login/generic_oauth)
# Puis activer ci-dessous :
GF_AUTH_GENERIC_OAUTH_ENABLED=false
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana
# openssl rand -base64 32
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=


# ── BACKUP (S82) ──────────────────────────────────────────────
# Répertoire local des backups (défaut: backup/data/ dans le projet)
BACKUP_DIR=

# Nombre de backups locaux à conserver (rotation automatique)
BACKUP_KEEP=7

# Restic — dépôt distant (optionnel)
# Formats : /chemin/local  |  b2:bucket:path  |  s3:s3.amazonaws.com/bucket  |  sftp:user@host:/path
# Laisser vide pour désactiver le push distant
BACKUP_RESTIC_REPO=
# openssl rand -base64 32
BACKUP_PASSWORD=

# Backblaze B2 (si BACKUP_RESTIC_REPO=b2:...)
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# AWS S3 (si BACKUP_RESTIC_REPO=s3:...)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
