# ============================================================
#  Configuration globale — copier en .env et remplir les valeurs
#  cp .env.example .env
#  Puis : make start
# ============================================================


# ── GATEWAY (LiteLLM) ────────────────────────────────────────
# Clé maître LiteLLM — à changer obligatoirement (openssl rand -hex 32)
LITELLM_MASTER_KEY=
GATEWAY_MASTER_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Serveur Ollama local (ex: http://100.x.x.x:11434 via NetBird, http://192.168.1.x:11434 en LAN)
# Laisser vide pour désactiver les modèles locaux
OLLAMA_URL=


# ── ASSISTANT ────────────────────────────────────────────────
GATEWAY_API_KEY=sk-assistant
GATEWAY_MODEL=openai/gpt-4o

# Auth Keycloak (false par défaut)
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=forge
KEYCLOAK_CLIENT_ID=assistant-app
# openssl rand -base64 32
VAULT_SECRET=change_this_vault_secret_32_chars!!

# Base de données assistant — obligatoire pour scaler (vide = SQLite local)
# postgresql://user:password@host:5432/assistant
ASSISTANT_DATABASE_URL=

# Redis — obligatoire pour scaler (pub/sub SSE + leader election scheduler)
# Sans Redis : single-instance uniquement
ASSISTANT_REDIS_URL=redis://redis:6379

# RAG — injection automatique de souvenirs MemPalace dans le chat
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.7

# Voice locale (nécessite LOCAL_VOICE_ENABLED=true au docker build)
LOCAL_VOICE_ENABLED=false
WHISPER_LOCAL_MODEL=base
KOKORO_VOICE=af_heart
KOKORO_LANG=a

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=


# ── FORGE ────────────────────────────────────────────────────
# LLM par défaut dans Forge (ollama | anthropic | openai | groq)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# Clés LLM optionnelles
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Keycloak Forge
KEYCLOAK_ADMIN=admin
# openssl rand -base64 24
KEYCLOAK_ADMIN_PASSWORD=change_this_in_production
# openssl rand -base64 32
ENCRYPTION_KEY=change_this_32_char_random_key!!

# Emails (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# MinIO Forge
MINIO_ROOT_USER=forge
# openssl rand -base64 16
MINIO_ROOT_PASSWORD=forge_secret_change_this

# MemPalace (optionnel — intégration Forge)
MEMPALACE_API_URL=http://localhost:8100
MEMPALACE_API_TOKEN=


# ── MEMPALACE ────────────────────────────────────────────────
# openssl rand -base64 32
MEMPALACE_JWT_SECRET=change_this_in_production
# openssl rand -hex 24
MEMPALACE_ADMIN_TOKEN=change_this_admin_token

MEMPALACE_MINIO_USER=mempalace
MEMPALACE_MINIO_PASSWORD=mempalace_secret_change_this


# ── ORIA ─────────────────────────────────────────────────────
ORIA_POSTGRES_USER=oria
# openssl rand -base64 16
ORIA_POSTGRES_PASSWORD=change_this_in_production
ORIA_POSTGRES_DB=oria

# openssl rand -base64 32
ORIA_LIVEKIT_API_SECRET=change_this_livekit_secret_32_chars

# Matrix/Synapse
ORIA_MATRIX_SERVER_NAME=oria.local
# openssl rand -hex 32
ORIA_MATRIX_AS_TOKEN=change_this_application_service_token
# openssl rand -hex 32
ORIA_MATRIX_HS_TOKEN=change_this_homeserver_token
# openssl rand -base64 16
ORIA_SYNAPSE_DB_PASSWORD=change_this_in_production

ORIA_MINIO_USER=oria
ORIA_MINIO_PASSWORD=oria_secret_change_this

# URLs publiques Oria (exposées au navigateur)
VITE_ORIA_API_URL=http://localhost:8000
VITE_ORIA_KEYCLOAK_URL=http://localhost:8080


# ── OBSERVABILITÉ (Prometheus + Grafana) ─────────────────────
# Mot de passe admin Grafana
# openssl rand -base64 16
GF_SECURITY_ADMIN_PASSWORD=change_this_grafana_password

# URL publique Grafana (pour les redirects OAuth)
GRAFANA_ROOT_URL=http://localhost:3100

# Keycloak OIDC pour Grafana (SSO multi-utilisateurs)
# Créer un client "grafana" dans Keycloak (type: confidential, redirect: GRAFANA_ROOT_URL/login/generic_oauth)
# Puis activer ci-dessous :
GF_AUTH_GENERIC_OAUTH_ENABLED=false
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana
# openssl rand -base64 32
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=
