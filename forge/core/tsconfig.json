{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/.bun/bun-types@1.3.13/node_modules"
    ]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
