# Usage standalone uniquement (docker compose -f forge/docker-compose.standalone.yml).
# Via Makefile racine : cp .env.example .env && make seed-envs && make start-forge

# ── LLM Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key
OPENROUTER_API_KEY=your_openrouter_key
MISTRAL_API_KEY=your_mistral_key
GEMINI_API_KEY=your_gemini_key
OLLAMA_BASE_URL=http://localhost:11434
# Pont Ollama — pour accéder au LLM local depuis téléphone / conteneur Docker
# Lance infra/ollama-bridge/ puis pointe OLLAMA_BASE_URL vers le bridge
# Exemple réseau local : OLLAMA_BASE_URL=http://192.168.1.100:11436
# Exemple Docker       : OLLAMA_BASE_URL=http://host.docker.internal:11436
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ── Default provider (ollama | anthropic | openai | groq) ──
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# ── Qdrant ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Keycloak ────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_in_production
KEYCLOAK_REALM=forge

# ── NetBird ─────────────────────────────────────────────────
NETBIRD_API_URL=https://api.netbird.io
NETBIRD_TOKEN=nbp_your_personal_access_token
# 32-byte base64 key: openssl rand -base64 32
NETBIRD_DATASTORE_ENCRYPTION_KEY=change_this_base64_32_byte_key

# ── Security ────────────────────────────────────────────────
# 32-char random key: openssl rand -base64 32
ENCRYPTION_KEY=change_this_32_char_random_key!!

# ── Voice / Search ──────────────────────────────────────────
BRAVE_SEARCH_API_KEY=your_brave_key
DEEPGRAM_API_KEY=your_deepgram_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# ── Services ────────────────────────────────────────────────
CORE_PORT=3001
FRONTEND_URL=http://localhost:3000
ML_MODULE_URL=http://localhost:8001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=forge
VITE_KEYCLOAK_CLIENT_ID=forge-app
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=forge

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Forge <your_email@gmail.com>

# ── MemPalace (opt-in) ───────────────────────────────────────
# Enrichit le RAG Forge avec les souvenirs MemPalace.
# 1) Démarrer MemPalace : cd mempalace && make start
# 2) Créer un token : POST /auth/service-token (username/password)
# 3) Renseigner ici :
MEMPALACE_API_URL=http://localhost:8100
MEMPALACE_API_TOKEN=

# ── Web Push (VAPID) ────────────────────────────────────────
# Générer : bun run web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@localhost
