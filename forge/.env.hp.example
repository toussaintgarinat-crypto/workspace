# forge/.env.hp.example — Copier en .env dans le LXC forge (10.10.10.10)
# Déployer avec : docker compose -f docker-compose.standalone.yml up -d
# Sur HP, Keycloak tourne dans le LXC infra (10.10.10.2), pas dans ce compose.

# Keycloak dans le LXC infra
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Ollama sur Mac via NetBird (remplacer NETBIRD_MAC_IP)
OLLAMA_BASE_URL=http://NETBIRD_MAC_IP:11434/api
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# Gateway LiteLLM dans le LXC gateway
GATEWAY_BASE_URL=http://10.10.10.50:4000
GATEWAY_API_KEY=sk-forge

# URL du frontend exposé (via Traefik ou IP directe)
FRONTEND_URL=http://10.10.10.10:3000

ENCRYPTION_KEY=change_this_32_char_random_key!!
